<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackageId>MediaPlayer.Native.Interop</PackageId>
    <Title>MediaPlayer Native Interop</Title>
    <Description>Managed interop provider catalogs and runtime helpers for MediaPlayer native playback and media workflow backends.</Description>
    <PackageTags>$(PackageTags);interop;native-playback</PackageTags>
    <Configurations>Release;Debug</Configurations>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MediaPlayer.Native.Abstractions\MediaPlayer.Native.Abstractions.csproj" />
  </ItemGroup>

</Project>
